# Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=super_secret_ai_digital_twin_jwt_token_key

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/ai-digital-twin

# Firebase Admin SDK Configuration (Optional - Mock Auth will trigger if not provided)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# Gemini API Configuration (Required for AI features, otherwise mock service executes)
GEMINI_API_KEY=your-gemini-api-key

# Pinecone Vector DB Configuration (Optional - Mock Vector DB uses memory vector storage if not set)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=ai-digital-twin

# Cloudinary Storage Configuration (Optional - Mock Cloudinary uploads locally to memory/disk)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
